# ─────────────────────────────────────────────────────────────────────────────
# 4kHDHub — Environment Variables
# Copy this file to .env.local for local dev
# In Cloudflare Pages: add these in Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── TMDB ─────────────────────────────────────────────────────────────────────
# Get free key at: https://www.themoviedb.org/settings/api
# This is also saved in DB via Admin → API Settings
TMDB_API_KEY=your-tmdb-api-key-here

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a random 32+ character string — used to sign JWTs
# Run: openssl rand -base64 32
JWT_SECRET=change-this-to-a-random-32-char-string-minimum

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-site.pages.dev
